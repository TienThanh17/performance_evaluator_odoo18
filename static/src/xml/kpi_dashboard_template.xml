<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

  <t t-name="performance_evaluator.KpiDashboardStandalone">
    <div class="o_kpi_dashboard_page">

      <!-- Selector Bar -->
      <div class="o_kpi_selector_bar">
        <div class="o_kpi_selector_left">
          <i class="fa fa-tachometer o_kpi_selector_icon"/>
          <span class="o_kpi_selector_title">Individual Performance Dashboard</span>
        </div>
        <div class="o_kpi_selector_right">
          <!-- Bộ lọc Department & Employee (Chỉ dành cho Manager) -->
          <t t-if="state.isManager || state.isHR || state.isAdmin">
            <!-- Chọn phòng ban -->
            <label class="o_kpi_selector_label">Department:</label>
            <select class="o_kpi_selector_select o_kpi_dept_select" t-on-change="onSelectDepartment">
              <option t-if="state.isHR || state.isAdmin" value="">All Departments</option>
              <t t-foreach="state.departments" t-as="dept" t-key="dept.id">
                <option t-att-value="dept.id" t-att-selected="dept.id === state.selectedDepartmentId" t-esc="dept.name"/>
              </t>
            </select>

            <!-- Chọn nhân viên (Data đã được lọc) -->
            <label class="o_kpi_selector_label">Employee:</label>
            <select class="o_kpi_selector_select o_kpi_employee_select" t-on-change="onSelectEmployee">
              <t t-foreach="state.filteredEmployees" t-as="emp" t-key="emp.id">
                <option t-att-value="emp.id" t-att-selected="emp.id === state.selectedEmployeeId" t-esc="emp.name"/>
              </t>
            </select>
          </t>

          <!-- Chọn kỳ đánh giá (Hiển thị nếu nhân viên đó có dữ liệu) -->
          <t t-if="state.evaluations.length">
            <label class="o_kpi_selector_label">Evaluation:</label>
            <select class="o_kpi_selector_select o_kpi_eval_select" t-on-change="onSelectEval">
              <t t-foreach="state.evaluations" t-as="ev" t-key="ev.id">
                <option t-att-value="ev.id" t-att-selected="ev.id === state.selectedEvaluationId" t-esc="evalOptionLabel(ev)"/>
              </t>
            </select>
          </t>
        </div>
      </div>

      <!-- Loading -->
      <div t-if="state.phase === 'evals' || state.phase === 'dashboard'" class="o_kpi_loading">
        <div class="o_kpi_spinner"/>
        <p>Loading…</p>
      </div>

      <!-- Error -->
      <div t-elif="state.phase === 'error'" class="o_kpi_error_state">
        <i class="fa fa-exclamation-triangle fa-2x"/>
        <p t-esc="state.errorMsg"/>
      </div>

      <!-- Empty state -->
      <div t-elif="!state.data" class="o_kpi_empty_state">
        <i class="fa fa-bar-chart fa-3x"/>
        <p>No performance evaluations found.</p>
      </div>

      <!-- Dashboard body -->
      <div t-else="" class="o_kpi_dashboard">

        <!-- Header -->
        <!-- <div class="o_kpi_header">
      <div class="o_kpi_header_left">
