<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="performance_evaluator.KpiTreeDashboard">
<div class="o_kpi_tree_page">

  <!-- ══ Header Bar ══ -->
  <div class="o_kpi_tree_header">
    <div class="o_kpi_tree_brand">
      <i class="fa fa-sitemap"/>
      <span>KPI Tree Dashboard</span>
    </div>

    <div class="o_kpi_tree_controls">
      <!-- Period Selector -->
      <div class="o_kpi_tree_control_group" t-if="!state.loading and state.data and state.data.available_periods.length">
        <label class="o_kpi_tree_label">Kỳ:</label>
        <select class="o_kpi_tree_select" t-on-change="onPeriodChange">
          <t t-foreach="state.data.available_periods" t-as="p" t-key="p_index">
            <option
              t-att-value="p_index"
              t-att-selected="state.selectedPeriod and state.selectedPeriod.start === p.start"
              t-esc="p.label"
            />
          </t>
        </select>
      </div>

      <!-- Metric Selector -->
      <div class="o_kpi_tree_control_group" t-if="!state.loading">
        <label class="o_kpi_tree_label">Hiển thị:</label>
        <select class="o_kpi_tree_select" t-on-change="onMetricChange">
          <option value="final" t-att-selected="state.metric === 'final'">Điểm cuối (Final)</option>
          <option value="perf" t-att-selected="state.metric === 'perf'">KPI cá nhân</option>
          <option value="dept" t-att-selected="state.metric === 'dept'">KPI phòng ban</option>
        </select>
      </div>
    </div>
  </div>

  <!-- ══ Loading State ══ -->
  <div t-if="state.loading" class="o_kpi_tree_body">
    <!-- Skeleton 6 cards -->
    <div class="o_kpi_tree_metric_row">
      <t t-foreach="[1,2,3,4,5,6]" t-as="i" t-key="i">
        <div class="o_kpi_tree_metric_card skeleton">
          <div class="sk-title"/>
          <div class="sk-value"/>
          <div class="sk-sub"/>
        </div>
      </t>
    </div>
    <!-- Skeleton tree placeholder -->
    <div class="o_kpi_tree_main">
      <div class="o_kpi_tree_svg_wrap skeleton-tree">
        <div class="sk-tree-placeholder">
          <i class="fa fa-sitemap fa-3x"/>
          <p>Đang tải dữ liệu KPI...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ Dashboard Body ══ -->
  <div t-elif="!state.loading and state.data" class="o_kpi_tree_body">

    <!-- ── 6 Metric Cards ── -->
    <div class="o_kpi_tree_metric_row">

      <!-- Card 1: KPI Công ty (REAL DATA) -->
      <div class="o_kpi_tree_metric_card card-blue" t-on-click="selectCompanyNode">
        <div class="metric-icon"><i class="fa fa-globe"/></div>
        <div class="metric-body">
          <div class="metric-label">KPI Công ty</div>
          <div class="metric-value" t-esc="formatScore(state.data.company.dept_kpi_score)"/>
          <div class="metric-sub">/ 100 điểm</div>
        </div>
      </div>

      <!-- Card 2: KPI Hoạt động (REAL DATA — pass_rate = % đạt + xuất sắc) -->
      <div class="o_kpi_tree_metric_card card-green" t-on-click="selectCompanyNode">
        <div class="metric-icon"><i class="fa fa-check-circle"/></div>
        <div class="metric-body">
          <div class="metric-label">KPI Hoạt động</div>
          <div class="metric-value" t-esc="formatPassRate(state.data.company.pass_rate)"/>
          <div class="metric-sub">% đạt &amp; xuất sắc</div>
        </div>
      </div>

      <!-- Card 3: KPI Tài chính (HARDCODE — chưa tích hợp) -->
      <div class="o_kpi_tree_metric_card card-amber">
        <div class="metric-icon"><i class="fa fa-usd"/></div>
        <div class="metric-body">
          <div class="metric-label">KPI Tài chính</div>
          <div class="metric-value">—</div>
          <!-- HARDCODE: Chưa tích hợp module kế toán -->
          <div class="metric-sub">Chưa tích hợp</div>
        </div>
      </div>

      <!-- Card 4: KPI Rủi ro (REAL DATA) -->
      <div class="o_kpi_tree_metric_card card-red" t-on-click="selectCompanyNode">
        <div class="metric-icon"><i class="fa fa-exclamation-triangle"/></div>
        <div class="metric-body">
          <div class="metric-label">KPI Rủi ro</div>
          <div class="metric-value" t-esc="state.data.risk_kpis.length"/>
          <div class="metric-sub">KPI điểm thấp</div>
        </div>
      </div>

      <!-- Card 5: KPI Thiếu dữ liệu (REAL DATA) -->
      <div class="o_kpi_tree_metric_card card-purple" t-on-click="selectCompanyNode">
        <div class="metric-icon"><i class="fa fa-database"/></div>
        <div class="metric-body">
          <div class="metric-label">Thiếu dữ liệu</div>
          <div class="metric-value" t-esc="state.data.missing_data_kpis.length"/>
          <div class="metric-sub">KPI chưa nhập</div>
        </div>
      </div>

      <!-- Card 6: Cảnh báo logic (HARDCODE từ backend = 2) -->
      <div class="o_kpi_tree_metric_card card-gray" t-on-click="selectCompanyNode">
        <div class="metric-icon"><i class="fa fa-bell"/></div>
        <div class="metric-body">
          <div class="metric-label">Cảnh báo logic</div>
          <div class="metric-value" t-esc="state.data.logic_warnings"/>
          <!-- HARDCODE: logic_warnings = 2 — chưa có engine kiểm tra -->
          <div class="metric-sub">Cần kiểm tra</div>
        </div>
      </div>

    </div>

    <!-- ── Main: Tree + Detail Panel ── -->
    <div class="o_kpi_tree_main">

      <!-- ── SVG Tree ── -->
      <div class="o_kpi_tree_svg_wrap" t-if="state.data.departments.length > 0">
        <div t-ref="d3_container" class="w-100 h-100 d3-kpi-container"></div>
      </div>

      <!-- Empty State -->
      <div t-else="" class="empty-state">
        <i class="fa fa-sitemap fa-3x"/>
        <p>Chưa có dữ liệu KPI cho kỳ này.</p>
        <p>Hãy tạo phiếu đánh giá từ menu mẫu KPI Phòng ban hoặc chọn kỳ khác.</p>
      </div>

      <!-- ── Detail Panel (bên phải) ── -->
      <div class="o_kpi_tree_detail_panel" t-if="state.selectedNode">
        <div class="panel-header">
          <span class="panel-close" t-on-click="closePanel"><i class="fa fa-times"/></span>

          <!-- type = company -->
          <t t-if="state.selectedNode.type === 'company'">
            <div class="panel-title"><i class="fa fa-globe"/> Công ty</div>
            <div class="panel-sub">Tổng quan toàn công ty</div>
          </t>

          <!-- type = dept -->
          <t t-elif="state.selectedNode.type === 'dept'">
            <div class="panel-title"><i class="fa fa-building"/> <t t-esc="state.selectedNode.data.name"/></div>
            <div class="panel-sub" t-esc="state.selectedNode.data.manager_name or 'Chưa có quản lý'"/>
          </t>

          <!-- type = emp -->
          <t t-elif="state.selectedNode.type === 'emp'">
            <div class="panel-avatar">
              <img t-att-src="state.selectedNode.data.avatar_url"
                   t-att-alt="state.selectedNode.data.name"
                   onerror="this.style.display='none'"
              />
            </div>
            <div class="panel-title" t-esc="state.selectedNode.data.name"/>
            <div class="panel-sub" t-esc="state.selectedNode.data.job or ''"/>
          </t>
        </div>

        <div class="panel-body">

          <!-- ── Company detail ── -->
          <t t-if="state.selectedNode.type === 'company'">
            <div class="panel-metric">
              <span class="pm-label">KPI phòng ban:</span>
              <span class="pm-value" t-esc="formatScore(state.selectedNode.data.dept_kpi_score) + ' / 100'"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">Tổng nhân sự:</span>
              <span class="pm-value" t-esc="state.selectedNode.data.total_employees"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">Số phòng ban:</span>
              <span class="pm-value" t-esc="state.selectedNode.data.total_depts"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">Tỷ lệ đạt:</span>
              <span class="pm-value" t-esc="formatPassRate(state.selectedNode.data.pass_rate)"/>
            </div>
            <div class="panel-note">* Trend theo quý sẽ cập nhật sau</div>
          </t>

          <!-- ── Dept detail ── -->
          <t t-elif="state.selectedNode.type === 'dept'">
            <div class="panel-metric">
              <span class="pm-label">KPI phòng ban:</span>
              <span class="pm-value" t-esc="formatScore(state.selectedNode.data.dept_kpi_score) + ' / 100'"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">Nhân viên:</span>
              <span class="pm-value" t-esc="state.selectedNode.data.employee_count"/>
            </div>
            <div class="panel-formula">
              Công thức: dept_kpi × w_dept + avg_cá_nhân × (1 − w_dept)
            </div>
            <!-- Sparkline HARDCODE -->
            <div class="panel-sparkline">
              <div class="spark-label">Trend (hardcode mẫu) *</div>
              <svg width="120" height="40" class="sparkline-svg">
                <path t-att-d="sparklinePath(sparklinePoints)" fill="none" stroke="#378ADD" stroke-width="2"/>
              </svg>
              <div class="panel-note">* Trend hardcode — cần get_kpi_trend()</div>
            </div>
          </t>

          <!-- ── Employee detail ── -->
          <t t-elif="state.selectedNode.type === 'emp'">
            <div class="panel-metric">
              <span class="pm-label">Final Score:</span>
              <span class="pm-value highlight" t-esc="formatScore(state.selectedNode.data.final_score) + ' / 100'"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">KPI cá nhân:</span>
              <span class="pm-value" t-esc="formatScore(state.selectedNode.data.performance_score)"/>
            </div>
            <div class="panel-metric">
              <span class="pm-label">KPI phòng ban:</span>
              <span class="pm-value" t-esc="formatScore(state.selectedNode.data.dept_kpi_score)"/>
            </div>
            <div class="panel-formula">
              <t t-esc="formatScore(state.selectedNode.data.dept_kpi_score)"/> × 0.4 +
              <t t-esc="formatScore(state.selectedNode.data.performance_score)"/> × 0.6 =
              <b><t t-esc="formatScore(state.selectedNode.data.final_score)"/></b>
            </div>
            <div class="panel-metric">
              <span class="pm-label">Trạng thái:</span>
              <span t-att-class="stateBadgeClass(state.selectedNode.data.state)"
                    t-esc="stateBadgeLabel(state.selectedNode.data.state)"/>
            </div>
            <!-- Sparkline HARDCODE -->
            <div class="panel-sparkline">
              <div class="spark-label">Trend (hardcode mẫu) *</div>
              <svg width="120" height="40" class="sparkline-svg">
                <path t-att-d="sparklinePath(sparklinePoints)" fill="none" stroke="#1D9E75" stroke-width="2"/>
              </svg>
              <div class="panel-note">* Trend hardcode — cần get_kpi_trend()</div>
            </div>
          </t>

        </div>
      </div>

    </div><!-- /o_kpi_tree_main -->

    <!-- ── 4 Panels phía dưới ── -->
    <div class="o_kpi_tree_panels">

      <!-- Panel 1: Top KPI rủi ro (REAL DATA) -->
      <div class="o_kpi_tree_panel">
        <div class="panel-head"><i class="fa fa-exclamation-triangle"/> Top KPI Rủi ro</div>
        <t t-if="state.data.risk_kpis.length > 0">
          <t t-foreach="state.data.risk_kpis" t-as="item" t-key="item_index">
            <div class="risk-row">
              <div class="risk-info">
                <span class="risk-name" t-esc="item.kpi_name"/>
                <span class="risk-meta"><t t-esc="item.dept_name"/> · <t t-esc="item.employee_name"/></span>
              </div>
              <div class="risk-right">
                <span class="risk-score" t-esc="(item.score * 10).toFixed(1) + '%'"/>
                <span t-att-class="levelBadgeClass(item.level)" t-esc="item.level"/>
              </div>
            </div>
          </t>
        </t>
        <div t-else="" class="panel-empty">Không có KPI rủi ro</div>
      </div>

      <!-- Panel 2: Đóng góp phòng ban (score REAL DATA, trọng số HARDCODE) -->
      <div class="o_kpi_tree_panel">
        <div class="panel-head"><i class="fa fa-building"/> Đóng góp phòng ban</div>
        <!-- Ghi chú: Score lấy từ real data; trọng số đóng góp hardcode (chưa có config) -->
        <t t-foreach="state.data.departments" t-as="dept" t-key="dept.id">
          <div class="dept-row">
            <div class="dept-name" t-esc="dept.name"/>
            <div class="dept-bar-wrap">
              <div class="dept-bar"
                t-att-style="'width:' + Math.min(100, (dept.dept_kpi_score || 0) * 10) + '%;'">
              </div>
            </div>
            <div class="dept-score" t-esc="((dept.dept_kpi_score || 0) * 10).toFixed(1) + '%'"/>
          </div>
        </t>
        <div class="panel-note">* Trọng số đóng góp hardcode — cần cấu hình</div>
      </div>

      <!-- Panel 3: KPI thiếu dữ liệu (REAL DATA) -->
      <div class="o_kpi_tree_panel">
        <div class="panel-head"><i class="fa fa-database"/> KPI Thiếu dữ liệu</div>
        <t t-if="state.data.missing_data_kpis.length > 0">
          <t t-foreach="state.data.missing_data_kpis" t-as="item" t-key="item_index">
            <div class="miss-row">
              <div class="miss-info">
                <span class="miss-name" t-esc="item.kpi_name"/>
                <span class="miss-meta"><t t-esc="item.dept_name"/> · <t t-esc="item.employee_name"/></span>
              </div>
              <span class="tag-missing">Thiếu dữ liệu</span>
            </div>
          </t>
        </t>
        <div t-else="" class="panel-empty">Tất cả KPI đã có dữ liệu ✓</div>
      </div>

      <!-- Panel 4: Insight điều hành AI (FULL HARDCODE) -->
      <div class="o_kpi_tree_panel panel-ai">
        <div class="panel-head"><i class="fa fa-lightbulb-o"/> Insight điều hành AI</div>
        <!-- HARDCODE: Dữ liệu mẫu — tích hợp AI sau -->
        <div class="ai-insight">
          <i class="fa fa-arrow-up text-success"/> Phòng ban có KPI tăng mạnh nhất tháng này: <b>IT Development</b>
          <div class="panel-note">Dữ liệu mẫu — tích hợp AI sau</div>
        </div>
        <div class="ai-insight">
          <i class="fa fa-exclamation text-warning"/> 2 nhân viên có nguy cơ không đạt KPI cuối kỳ
          <div class="panel-note">Dữ liệu mẫu — tích hợp AI sau</div>
        </div>
        <div class="ai-insight">
          <i class="fa fa-clock-o text-danger"/> Tỷ lệ chấm công phòng Sales giảm 12% so với kỳ trước
          <div class="panel-note">Dữ liệu mẫu — tích hợp AI sau</div>
        </div>
      </div>

    </div><!-- /o_kpi_tree_panels -->

  </div><!-- /o_kpi_tree_body -->

  <!-- ══ Empty (no data at all) ══ -->
  <div t-elif="!state.loading and !state.data" class="o_kpi_tree_body">
    <div class="empty-state">
      <i class="fa fa-sitemap fa-3x"/>
      <p>Không thể tải dữ liệu KPI.</p>
      <p>Vui lòng kiểm tra lại kết nối hoặc liên hệ quản trị viên.</p>
    </div>
  </div>

</div><!-- /o_kpi_tree_page -->
</t>

</templates>
