<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_hr_department_form_inherit_kpi_score" model="ir.ui.view">
            <field name="name">hr.department.view.form.inherit.kpi.score</field>
            <field name="model">hr.department</field>
            <field name="inherit_id" ref="hr.view_department_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button" name="action_department_score_view"
                            type="object" icon="fa-trophy">
                        <field name="dept_kpi_score" widget="statinfo" string="KPI Score"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
