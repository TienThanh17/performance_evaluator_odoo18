<odoo>
    <data noupdate="1">

        <!-- Security category -->
        <record id="module_hr_performance_evaluation" model="ir.module.category">
            <field name="name">HR Performance Evaluator</field>
            <field name="description">KPI templates &amp; employee performance evaluations</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groups / Roles -->
        <record id="group_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
        </record>

        <record id="group_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
            <field name="implied_ids" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_employee'))]"/>
        </record>

        <record id="group_hr" model="res.groups">
            <field name="name">HR</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
        </record>

        <record id="group_admin" model="res.groups">
            <field name="name">Admin (Dev)</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
            <field name="implied_ids" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_hr'))]"/>
        </record>


        <!-- ============================ -->
        <!-- Record Rules: Evaluation -->
        <!-- ============================ -->
        <!-- Employee: only own evaluations -->
        <record id="rule_eval_employee_own" model="ir.rule">
            <field name="name">Evaluation: Employee - Own Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_employee'))]"/>
        </record>

        <!-- Manager: evaluations of direct reports -->
        <record id="rule_eval_manager_team" model="ir.rule">
            <field name="name">Evaluation: Manager - Team Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">[('employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_manager'))]"/>
        </record>

        <!-- HR: see all -->
        <record id="rule_eval_hr_all" model="ir.rule">
            <field name="name">Evaluation: HR - All Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_hr'))]"/>
        </record>

        <!-- Admin: bypass -->
        <record id="rule_eval_admin_all" model="ir.rule">
            <field name="name">Evaluation: Admin - Bypass</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_admin'))]"/>
        </record>


        <!-- ================================= -->
        <!-- Record Rules: Evaluation Line -->
        <!-- ================================= -->
        <!-- Employee: only lines of own evaluation -->
        <record id="rule_eval_line_employee_own" model="ir.rule">
            <field name="name">Evaluation Line: Employee - Own Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">[('evaluation_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_employee'))]"/>
        </record>

        <!-- Manager: lines for direct reports -->
        <record id="rule_eval_line_manager_team" model="ir.rule">
            <field name="name">Evaluation Line: Manager - Team Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">[('evaluation_id.employee_id.parent_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_manager'))]"/>
        </record>

        <!-- HR: see all lines -->
        <record id="rule_eval_line_hr_all" model="ir.rule">
            <field name="name">Evaluation Line: HR - All Records</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_hr'))]"/>
        </record>

        <!-- Admin: bypass -->
        <record id="rule_eval_line_admin_all" model="ir.rule">
            <field name="name">Evaluation Line: Admin - Bypass</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_admin'))]"/>
        </record>

    </data>
</odoo>
