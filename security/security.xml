<odoo>
    <data noupdate="1">

        <!-- Define the Performance Evaluation module category -->
        <record id="module_hr_performance_evaluation" model="ir.module.category">
            <field name="name">Performance Evaluation</field>
            <field name="description">Manage employee performance evaluations</field>
            <field name="sequence">10</field>
        </record>

        <!-- Manager Group -->
        <record id="group_evaluation_manager" model="res.groups">
            <field name="name">Evaluation Manager</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
        </record>

        <!-- User Group -->
        <record id="group_evaluation_user" model="res.groups">
            <field name="name">Evaluation User</field>
            <field name="category_id" ref="custom_adecsol_hr_performance_evaluator.module_hr_performance_evaluation"/>
        </record>

        <record id="rule_manager_access" model="ir.rule">
            <field name="name">Manager Access Rule</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">['|',('user_id','=',user.id),('manager_id.user_id.id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_evaluation_manager'))]"/>
        </record>

        <!-- User Rule: Users can see only their own evaluations -->
        <record id="rule_user_access" model="ir.rule">
            <field name="name">User Access Rule</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation"/>
            <field name="domain_force">
               [('employee_id.user_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_evaluation_user'))]"/>
        </record>

        <!-- Lines: Manager access rule -->
        <record id="rule_manager_access_line" model="ir.rule">
            <field name="name">Manager Access Rule (Lines)</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">['|',('evaluation_id.user_id','=',user.id),('evaluation_id.manager_id.user_id.id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_evaluation_manager'))]"/>
        </record>

        <!-- Lines: User access rule -->
        <record id="rule_user_access_line" model="ir.rule">
            <field name="name">User Access Rule (Lines)</field>
            <field name="model_id" ref="custom_adecsol_hr_performance_evaluator.model_hr_performance_evaluation_line"/>
            <field name="domain_force">[('evaluation_id.employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('custom_adecsol_hr_performance_evaluator.group_evaluation_user'))]"/>
        </record>

    </data>
</odoo>
